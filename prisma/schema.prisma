generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Role {
  USER
  ADMIN
}

enum DropStatus {
  UPCOMING
  LIVE
  SOLD_OUT
  ENDED
}

enum OrderStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum ProductGender {
  MEN
  WOMEN
  KIDS
  UNISEX
}

enum ProductType {
  OXY
  APPAREL
  LIFESTYLE
  FOOTWEAR
  BRANDS
}

// ─── Auth (NextAuth v5 adapter) ───────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          Role      @default(USER)
  accounts      Account[]
  sessions      Session[]
  orders        Order[]
  createdAt     DateTime  @default(now())
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Drops ────────────────────────────────────────────────────────────────────

model Drop {
  id          String     @id @default(cuid())
  name        String
  slug        String     @unique
  description String?
  coverImage  String?
  scheduledAt DateTime?
  endsAt      DateTime?
  maxPerUser  Int        @default(1)
  status      DropStatus @default(UPCOMING)
  products    Product[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model Product {
  id         String        @id @default(cuid())
  dropId     String
  name       String
  price      Int           // stored in cents
  stock      Int           @default(0)
  sold       Int           @default(0)
  sku        String?
  image      String?
  gender     ProductGender @default(UNISEX)
  type       ProductType   @default(APPAREL)
  drop       Drop          @relation(fields: [dropId], references: [id], onDelete: Cascade)
  orderItems OrderItem[]
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
}

// ─── Orders ───────────────────────────────────────────────────────────────────

model Order {
  id                   String      @id @default(cuid())
  userId               String
  total                Int         // stored in cents
  status               OrderStatus @default(PENDING)
  shippingAddress      String?     // JSON-encoded shipping address
  stripePaymentIntentId String?    @unique
  user                 User        @relation(fields: [userId], references: [id])
  items                OrderItem[]
  createdAt            DateTime    @default(now())
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  productId String
  quantity  Int     @default(1)
  price     Int     // price snapshot in cents at time of purchase
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id])
}
